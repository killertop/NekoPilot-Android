<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="12dp"
    android:paddingBottom="20dp">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/np_bottom_sheet_handle" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="8dp"
        android:text="@string/nodes_empty_action"
        android:textColor="@color/np_text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/add_scan_qr"
        style="?attr/borderlessButtonStyle"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:gravity="start|center_vertical"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:text="@string/add_profile_methods_scan_qr_code"
        android:textColor="@color/np_text_primary"
        android:textSize="16sp"
        app:icon="@drawable/ic_baseline_qr_code_scanner_24"
        app:iconGravity="textStart"
        app:iconPadding="16dp"
        app:iconTint="@color/np_navy" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/add_from_clipboard"
        style="?attr/borderlessButtonStyle"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:gravity="start|center_vertical"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:text="@string/action_import"
        android:textColor="@color/np_text_primary"
        android:textSize="16sp"
        app:icon="@drawable/ic_baseline_content_paste_24"
        app:iconGravity="textStart"
        app:iconPadding="16dp"
        app:iconTint="@color/np_navy" />

</LinearLayout>
