<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/np_background"
    android:clipToPadding="false"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/np_surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/np_divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/backup_contents"
                    android:textColor="@color/np_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/backup_configurations"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:checked="true"
                    android:text="@string/backup_groups_and_configurations"
                    android:textColor="@color/np_text_primary" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/backup_rules"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:checked="true"
                    android:text="@string/backup_rules"
                    android:textColor="@color/np_text_primary" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/backup_settings"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:checked="true"
                    android:text="@string/backup_settings"
                    android:textColor="@color/np_text_primary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="4dp"
            android:layout_marginTop="12dp"
            android:text="@string/backup_summary"
            android:textColor="@color/np_text_secondary"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/action_export"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="14dp"
            android:text="@string/action_export"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/np_navy"
            app:cornerRadius="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/action_share"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:text="@string/share"
            android:textColor="@color/np_navy"
            app:cornerRadius="16dp"
            app:strokeColor="@color/np_divider" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/action_import_file"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:text="@string/action_import_file"
            android:textColor="@color/np_navy"
            app:cornerRadius="16dp"
            app:strokeColor="@color/np_divider" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/reset_settings"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:text="@string/reset_settings"
            android:textColor="@color/np_error" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
