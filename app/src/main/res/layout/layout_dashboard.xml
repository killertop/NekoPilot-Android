<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/np_background"
    android:fitsSystemWindows="true">

    <ImageView
        android:layout_width="360dp"
        android:layout_height="360dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="92dp"
        android:alpha="0.035"
        android:contentDescription="@null"
        android:src="@mipmap/ic_launcher_monochrome"
        app:tint="@color/np_navy" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/app_name"
                android:textColor="@color/np_text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/settings_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/settings"
                android:padding="12dp"
                android:src="@drawable/ic_action_settings"
                app:tint="@color/np_text_primary" />
        </LinearLayout>

        <Space android:layout_width="1dp" android:layout_height="26dp" />

        <TextView
            android:id="@+id/connection_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/not_connected"
            android:textColor="@color/np_text_primary"
            android:textSize="30sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:orientation="horizontal">

            <View
                android:id="@+id/status_dot"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="@drawable/np_status_dot" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/dashboard_privacy_note"
                android:textColor="@color/np_text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/connect_button"
            android:layout_width="176dp"
            android:layout_height="176dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="30dp"
            android:background="@drawable/np_connect_halo"
            android:clickable="true"
            android:contentDescription="@string/connect"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/np_connect_button"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp">

                <ImageView
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:contentDescription="@null"
                    android:src="@mipmap/ic_launcher_monochrome"
                    app:tint="@color/white" />

                <TextView
                    android:id="@+id/connect_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/connect"
                    android:textColor="@color/white"
                    android:textSize="17sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/node_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/np_surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:rippleColor="@color/np_blue_soft"
            app:strokeColor="@color/np_divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/np_node_icon_background"
                    android:padding="14dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_baseline_location_on_24"
                        app:tint="@color/np_navy" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/node_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/dashboard_no_node"
                        android:textColor="@color/np_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/node_protocol"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/dashboard_choose_node"
                        android:textColor="@color/np_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/node_delay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textColor="@color/np_cyan"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="42 ms" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/traffic_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/np_surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/np_divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="92dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/dashboard_upload" android:textColor="@color/np_text_secondary" android:textSize="12sp" />
                <TextView android:id="@+id/upload_speed" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="0 B/s" android:textColor="@color/np_text_primary" android:textSize="18sp" android:textStyle="bold" />
            </LinearLayout>

            <View android:layout_width="1dp" android:layout_height="36dp" android:background="@color/np_divider" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/dashboard_download" android:textColor="@color/np_text_secondary" android:textSize="12sp" />
                <TextView android:id="@+id/download_speed" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="0 B/s" android:textColor="@color/np_text_primary" android:textSize="18sp" android:textStyle="bold" />
            </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>
