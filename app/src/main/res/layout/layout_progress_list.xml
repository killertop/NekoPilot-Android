<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="8dp"
    android:paddingEnd="24dp"
    android:paddingBottom="4dp">

    <TextView
        android:id="@+id/test_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceSubtitle1"
        android:textColor="@color/np_text_primary" />

    <TextView
        android:id="@+id/test_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="@string/connection_test_results_hint"
        android:textAppearance="?attr/textAppearanceCaption"
        android:textColor="@color/np_text_secondary" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/test_progress"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="16dp"
        android:contentDescription="@string/connection_test_testing"
        app:indicatorColor="@color/np_cyan"
        app:trackColor="@color/np_blue_soft"
        app:trackCornerRadius="3dp" />

    <TextView
        android:id="@+id/progress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textAppearance="?attr/textAppearanceCaption"
        android:textColor="@color/np_text_secondary" />

    <TextView
        android:id="@+id/now_testing"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="start"
        android:minLines="2"
        android:maxLines="4"
        android:textAppearance="?attr/textAppearanceBody2"
        android:textColor="@color/np_text_primary"
        tools:text="当前节点\nDE · VLESS · 246ms" />

</LinearLayout>
