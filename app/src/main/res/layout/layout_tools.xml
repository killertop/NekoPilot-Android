<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/np_background"
    android:orientation="vertical"
    tools:context=".ui.ToolsFragment">

    <include
        layout="@layout/layout_appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tools_tab"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/np_surface"
        android:elevation="0dp"
        app:tabIndicatorColor="@color/np_cyan"
        app:tabIndicatorFullWidth="false"
        app:tabMode="fixed"
        app:tabPaddingStart="16dp"
        app:tabRippleColor="@color/np_blue_soft"
        app:tabSelectedTextColor="@color/np_navy"
        app:tabTextColor="@color/np_text_secondary"
        app:tabUnboundedRipple="false" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/tools_pager"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>
