<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/np_background"
    android:orientation="vertical"
    tools:context=".ui.ConfigurationFragment">

    <include
        layout="@layout/layout_appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/group_tab"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/np_surface"
        android:elevation="0dp"
        android:visibility="gone"
        app:tabIndicatorColor="@color/np_cyan"
        app:tabIndicatorFullWidth="false"
        app:tabMode="scrollable"
        app:tabPaddingStart="16dp"
        app:tabRippleColor="@color/np_blue_soft"
        app:tabSelectedTextColor="@color/np_navy"
        app:tabTextColor="@color/np_text_secondary"
        app:tabUnboundedRipple="false" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/group_pager"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <LinearLayout
            android:id="@+id/nodes_empty_state"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:padding="40dp"
            android:visibility="gone">

            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/np_node_icon_background"
                android:padding="20dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_action_note_add"
                    app:tint="@color/np_navy" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/nodes_empty_title"
                android:textColor="@color/np_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/nodes_empty_summary"
                android:textColor="@color/np_text_secondary"
                android:textSize="14sp" />

        </LinearLayout>

        <FrameLayout
            android:id="@+id/connection_fab"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="20dp"
            android:visibility="gone"
            android:elevation="8dp">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/connection_progress"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:indeterminate="true"
                android:visibility="gone"
                app:indicatorColor="@color/np_cyan"
                app:indicatorSize="76dp"
                app:trackColor="@color/np_blue_soft"
                app:trackThickness="3dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/connection_toggle"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:contentDescription="@string/connect"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:padding="16dp"
                android:text=""
                app:backgroundTint="@color/np_blue_soft"
                app:cornerRadius="32dp"
                app:elevation="4dp"
                app:icon="@drawable/ic_baseline_power_settings_new_24"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="28dp"
                app:iconTint="@color/np_text_secondary" />
        </FrameLayout>
    </FrameLayout>

</LinearLayout>
