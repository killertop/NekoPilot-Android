<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/np_background"
    android:orientation="vertical"
    tools:context=".ui.ConfigurationFragment">

    <include
        layout="@layout/layout_appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/connection_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/np_surface"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/np_divider"
        app:strokeWidth="1dp"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:id="@+id/connection_header_dot"
                    android:layout_width="7dp"
                    android:layout_height="7dp"
                    android:background="@drawable/np_status_dot" />

                <TextView
                    android:id="@+id/connection_header_state"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="@string/not_connected"
                    android:textColor="@color/np_text_secondary"
                    android:textSize="13sp" />

                <FrameLayout
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="8dp">

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/connection_progress"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:indeterminate="true"
                        android:visibility="gone"
                        app:indicatorColor="@color/np_cyan"
                        app:indicatorSize="56dp"
                        app:trackColor="@color/np_blue_soft"
                        app:trackThickness="3dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/connection_toggle"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/connect"
                        android:insetLeft="0dp"
                        android:insetTop="0dp"
                        android:insetRight="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:padding="12dp"
                        android:text=""
                        app:backgroundTint="@color/np_navy"
                        app:cornerRadius="24dp"
                        app:elevation="3dp"
                        app:icon="@drawable/ic_baseline_power_settings_new_24"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="24dp"
                        app:iconTint="@color/white" />
                </FrameLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:baselineAligned="false"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/np_node_icon_background"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_baseline_location_on_24"
                        app:tint="@color/np_navy" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/connection_header_node"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/dashboard_no_node"
                        android:textColor="@color/np_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/connection_header_meta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/dashboard_choose_node"
                        android:textColor="@color/np_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/connection_header_traffic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:layout_marginTop="12dp"
                android:background="@color/np_blue_soft"
                android:clickable="true"
                android:contentDescription="@string/connection_test"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingTop="9dp"
                android:paddingEnd="12dp"
                android:paddingBottom="9dp">

                <TextView
                    android:id="@+id/connection_header_upload"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/dashboard_upload"
                    android:textColor="@color/np_text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/connection_header_download"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:layout_weight="1"
                    android:text="@string/dashboard_download"
                    android:textColor="@color/np_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/group_tab"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/np_surface"
        android:elevation="0dp"
        android:visibility="gone"
        app:tabIndicatorColor="@color/np_cyan"
        app:tabIndicatorFullWidth="false"
        app:tabMode="scrollable"
        app:tabPaddingStart="16dp"
        app:tabRippleColor="@color/np_blue_soft"
        app:tabSelectedTextColor="@color/np_navy"
        app:tabTextColor="@color/np_text_secondary"
        app:tabUnboundedRipple="false" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/group_pager"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <LinearLayout
            android:id="@+id/nodes_empty_state"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="40dp"
            android:visibility="gone">

            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/np_node_icon_background"
                android:padding="20dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_action_note_add"
                    app:tint="@color/np_navy" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/nodes_empty_title"
                android:textColor="@color/np_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/nodes_empty_summary"
                android:textColor="@color/np_text_secondary"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/nodes_import_subscription"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:text="@string/import_subscription_link"
                android:textAllCaps="false"
                android:textColor="@color/white"
                app:backgroundTint="@color/np_navy"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_baseline_link_24"
                app:iconTint="@color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/nodes_import_clipboard"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="@string/nodes_import_clipboard"
                android:textAllCaps="false"
                android:textColor="@color/np_navy"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_file_file_upload"
                app:iconTint="@color/np_navy"
                app:strokeColor="@color/np_divider" />
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
