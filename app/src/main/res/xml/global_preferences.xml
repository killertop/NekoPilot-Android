<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory app:title="@string/advanced_connection_settings">
        <moe.matsuri.nb4a.ui.SimpleMenuPreference
            app:defaultValue="2"
            app:entries="@array/tun_implementation"
            app:entrySummaries="@array/tun_implementation_summaries"
            app:entryValues="@array/tun_implementation_values"
            app:icon="@drawable/ic_baseline_flip_camera_android_24"
            app:key="tunImplementation"
            app:title="@string/tun_implementation"
            app:useSimpleSummaryProvider="true" />
    </PreferenceCategory>

    <PreferenceCategory app:title="@string/inbound_settings">
        <SwitchPreference
            app:icon="@drawable/ic_baseline_nat_24"
            app:key="allowAccess"
            app:summary="@string/allow_access_sum"
            app:title="@string/allow_access" />
        <Preference
            app:icon="@drawable/ic_maps_directions_boat"
            app:key="localAccessInfo"
            app:title="@string/local_access_info" />
    </PreferenceCategory>

    <PreferenceCategory app:title="@string/settings_app_info">
        <Preference
            app:icon="@drawable/ic_baseline_info_24"
            app:key="settingsAbout"
            app:title="@string/menu_about" />
    </PreferenceCategory>

</PreferenceScreen>
