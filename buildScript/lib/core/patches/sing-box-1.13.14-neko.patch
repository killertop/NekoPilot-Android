+package boxapi
+
+import (
+	"context"
+	"net"
+
+	box "github.com/sagernet/sing-box"
+	"github.com/sagernet/sing-box/common/dialer"
+	"github.com/sagernet/sing/common/metadata"
+)
+
+func DialContext(ctx context.Context, box *box.Box, network, addr string) (net.Conn, error) {
+	defOutboundTag := box.Outbound().Default().Tag()
+	conn, err := dialer.NewDetour(box.Outbound(), defOutboundTag, true).DialContext(ctx, network, metadata.ParseSocksaddr(addr))
+	if err != nil {
+		return nil, err
+	}
+	return conn, nil
+}
